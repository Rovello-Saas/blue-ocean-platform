    "custom_liquid_cloned": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  /* =============================================\n     SUPPORT PILLOW CONTENT — Ergonomic pillow clone\n     Prefix: skc-\n  ============================================= */\n\n  .skc-wrap { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #1b2d5b; }\n\n  /* --- 1. TRUST BAR --- */\n  .skc-trust-bar {\n    background: #1b2d5b;\n    padding: 14px 20px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 60px;\n    flex-wrap: wrap;\n  }\n  .skc-trust-bar span {\n    color: #fff;\n    font-size: 14px;\n    font-weight: 600;\n    letter-spacing: 0.3px;\n  }\n  .skc-trust-bar span::before { content: \"✓ \"; color: #fff; }\n\n  /* --- 2. FIVE FEATURES (matches Snoozity layout) --- */\n  .skc-features {\n    padding: 40px 20px;\n    background: #fff;\n  }\n  .skc-features-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n    gap: 20px;\n    max-width: 1200px;\n    margin: 0 auto;\n  }\n  .skc-feature-item {\n    border-radius: 8px;\n    padding: 20px;\n    background: #fff;\n    text-align: left;\n  }\n  .skc-feature-img-wrap {\n    text-align: center;\n    margin-bottom: 15px;\n  }\n  .skc-feature-img-wrap img {\n    max-width: 100%;\n    height: auto;\n  }\n  .skc-feature-item h3 {\n    font-size: 16px;\n    font-weight: 700;\n    margin-bottom: 12px;\n    text-align: center;\n    color: #0d1a42;\n    text-transform: uppercase;\n  }\n  .skc-feature-item ul {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n  }\n  .skc-feature-item ul li {\n    font-size: 16px;\n    color: rgba(50, 61, 101, 0.9);\n    padding: 4px 0 4px 34px;\n    position: relative;\n    line-height: 1.8;\n  }\n  .skc-feature-item ul li::before {\n    content: \"\";\n    position: absolute;\n    left: 0;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 20px;\n    height: 20px;\n    background-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><circle cx='12' cy='12' r='12' fill='%230d47a1'/><path d='M6 12l4 4 8-8' fill='none' stroke='%23fff' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/></svg>\");\n    background-size: contain;\n    background-repeat: no-repeat;\n    background-position: center;\n  }\n\n  /* --- 3. DARK HERO --- */\n  .skc-hero {\n    background: #1b2d5b;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    align-items: center;\n    min-height: 420px;\n  }\n  .skc-hero-text { padding: 60px 60px 60px 80px; }\n  .skc-hero-text h2 {\n    font-size: 42px;\n    font-weight: 800;\n    color: #fff;\n    margin: 0 0 24px;\n    line-height: 1.15;\n  }\n  .skc-hero-text p {\n    font-size: 16px;\n    color: rgba(255,255,255,0.85);\n    margin: 0 0 24px;\n    line-height: 1.7;\n  }\n  .skc-hero-text ul {\n    list-style: none;\n    padding: 0; margin: 0;\n  }\n  .skc-hero-text ul li {\n    font-size: 15px;\n    color: rgba(255,255,255,0.9);\n    padding: 6px 0 6px 28px;\n    position: relative;\n  }\n  .skc-hero-text ul li::before {\n    content: \"✓\";\n    position: absolute; left: 0;\n    color: #60a5fa;\n    font-size: 16px;\n    font-weight: 700;\n  }\n  .skc-hero-img { position: relative; height: 100%; min-height: 420px; }\n  .skc-hero-img img { width: 100%; height: 100%; object-fit: cover; }\n\n  /* --- 4. USE CASES GRID --- */\n  .skc-usecases {\n    padding: 70px 40px;\n    background: #fff;\n    text-align: center;\n  }\n  .skc-usecases h2 {\n    font-size: 32px;\n    font-weight: 800;\n    color: #1b2d5b;\n    margin: 0 0 48px;\n  }\n  .skc-usecases-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 20px;\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n  .skc-usecase-card img {\n    width: 100%;\n    aspect-ratio: 1;\n    object-fit: cover;\n    border-radius: 16px;\n  }\n  .skc-usecase-card h4 {\n    font-size: 13px;\n    font-weight: 800;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    color: #1b2d5b;\n    margin: 14px 0 0;\n  }\n\n  /* --- 5. DARK STATS --- */\n  .skc-stats-section {\n    background: #1b2d5b;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    align-items: center;\n    padding: 0;\n  }\n  .skc-stats-left { padding: 60px 60px 60px 80px; }\n  .skc-stats-left h2 {\n    font-size: 30px;\n    font-weight: 800;\n    color: #fff;\n    margin: 0 0 20px;\n    line-height: 1.3;\n  }\n  .skc-stats-left p {\n    font-size: 15px;\n    color: rgba(255,255,255,0.8);\n    line-height: 1.7;\n    margin: 0 0 28px;\n  }\n  .skc-stats-left strong { color: #fff; }\n  .skc-stats-img { margin-top: 20px; }\n  .skc-stats-img img { width: 100%; border-radius: 12px; max-width: 360px; }\n  .skc-stats-right { padding: 60px 80px 60px 40px; }\n  .skc-stat-row {\n    display: grid;\n    grid-template-columns: 100px 1fr;\n    align-items: center;\n    gap: 20px;\n    padding: 18px 0;\n    border-bottom: 1px solid rgba(255,255,255,0.1);\n  }\n  .skc-stat-row:last-child { border-bottom: none; }\n  .skc-circle {\n    width: 80px; height: 80px;\n    position: relative;\n    flex-shrink: 0;\n  }\n  .skc-circle svg { width: 80px; height: 80px; transform: rotate(-90deg); }\n  .skc-circle-track { fill: none; stroke: rgba(255,255,255,0.15); stroke-width: 7; }\n  .skc-circle-fill { fill: none; stroke: #fff; stroke-width: 7; stroke-linecap: round; }\n  .skc-circle-num {\n    position: absolute;\n    top: 50%; left: 50%;\n    transform: translate(-50%,-50%);\n    font-size: 16px;\n    font-weight: 800;\n    color: #fff;\n  }\n  .skc-stat-text h4 {\n    font-size: 15px;\n    font-weight: 700;\n    color: #fff;\n    margin: 0 0 6px;\n  }\n  .skc-stat-text p {\n    font-size: 13px;\n    color: rgba(255,255,255,0.75);\n    margin: 0;\n    line-height: 1.5;\n  }\n\n  /* --- 6. REVIEWS --- */\n  .skc-reviews {\n    padding: 70px 40px;\n    background: #fff;\n    text-align: center;\n  }\n  .skc-reviews h2 {\n    font-size: 26px;\n    font-weight: 900;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #1b2d5b;\n    margin: 0 0 48px;\n  }\n  .skc-reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 28px;\n    max-width: 1100px;\n    margin: 0 auto;\n    text-align: left;\n  }\n  .skc-review-card {\n    border: 1px solid #e5e7eb;\n    border-radius: 16px;\n    padding: 28px;\n    position: relative;\n  }\n  .skc-review-photo {\n    width: 100%;\n    aspect-ratio: 4/3;\n    object-fit: cover;\n    border-radius: 10px;\n    margin-bottom: 16px;\n  }\n  .skc-review-quote {\n    position: absolute;\n    top: 16px; right: 16px;\n    width: 40px; height: 40px;\n    background: #1b2d5b;\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    color: #fff;\n    font-size: 18px;\n    font-weight: 900;\n  }\n  .skc-stars { color: #f59e0b; font-size: 18px; margin-bottom: 10px; }\n  .skc-review-card h4 {\n    font-size: 16px;\n    font-weight: 800;\n    color: #1b2d5b;\n    margin: 0 0 10px;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n  }\n  .skc-review-card p { font-size: 14px; color: #4b5563; line-height: 1.7; margin: 0 0 12px; }\n  .skc-review-card .skc-reviewer { font-size: 13px; font-weight: 600; color: #6b7280; font-style: italic; }\n\n  /* --- 7. COMPARISON TABLE --- */\n  .skc-compare {\n    padding: 70px 40px;\n    background: #f8f9ff;\n  }\n  .skc-compare-inner {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 60px;\n    max-width: 1100px;\n    margin: 0 auto;\n    align-items: center;\n  }\n  .skc-compare-text h2 {\n    font-size: 32px;\n    font-weight: 800;\n    color: #1b2d5b;\n    margin: 0 0 16px;\n    line-height: 1.3;\n  }\n  .skc-compare-text p { font-size: 15px; color: #4b5563; line-height: 1.7; }\n  .skc-compare-text strong { color: #1b2d5b; }\n  .skc-table { width: 100%; border-collapse: collapse; }\n  .skc-table thead th {\n    padding: 14px 20px;\n    font-size: 14px;\n    font-weight: 700;\n    color: #1b2d5b;\n    text-align: center;\n  }\n  .skc-table thead th:first-child { text-align: left; }\n  .skc-table tbody tr:nth-child(odd) { background: #fff; }\n  .skc-table tbody tr:nth-child(even) { background: #f0f4ff; }\n  .skc-table tbody td {\n    padding: 14px 20px;\n    font-size: 14px;\n    font-weight: 600;\n    color: #1b2d5b;\n    text-align: center;\n  }\n  .skc-table tbody td:first-child { text-align: left; border-radius: 8px 0 0 8px; }\n  .skc-table tbody td:last-child { border-radius: 0 8px 8px 0; }\n  .skc-check { color: #16a34a; font-size: 20px; font-weight: 900; }\n  .skc-cross { color: #dc2626; font-size: 20px; }\n  .skc-col-ours { background: #1b2d5b !important; color: #fff !important; border-radius: 0 !important; }\n  .skc-col-ours .skc-check { color: #86efac; }\n\n  /* --- 8. PHOTO STRIP --- */\n  .skc-photo-strip {\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 0;\n  }\n  .skc-photo-strip img {\n    width: 100%;\n    aspect-ratio: 3/4;\n    object-fit: cover;\n    display: block;\n  }\n\n  /* --- 9. EXPERTS --- */\n  .skc-experts {\n    padding: 70px 40px;\n    background: #fff;\n  }\n  .skc-experts h2 {\n    font-size: 28px;\n    font-weight: 800;\n    color: #1b2d5b;\n    margin: 0 0 48px;\n    text-align: center;\n    max-width: 700px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n  .skc-experts-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 40px;\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n  .skc-expert-img {\n    width: 100%;\n    aspect-ratio: 4/5;\n    object-fit: cover;\n    border-radius: 12px;\n    margin-bottom: 20px;\n    filter: grayscale(100%);\n  }\n  .skc-expert-quote {\n    font-size: 14px;\n    color: #4b5563;\n    line-height: 1.7;\n    font-style: italic;\n    margin: 0 0 16px;\n  }\n  .skc-expert-name {\n    font-size: 14px;\n    font-weight: 700;\n    color: #1b2d5b;\n    margin: 0 2px 2px;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .skc-expert-name svg { width: 18px; height: 18px; fill: #2563eb; flex-shrink: 0; }\n  .skc-expert-title { font-size: 13px; color: #6b7280; margin: 0; }\n\n  /* --- 10. FAQ --- */\n  .skc-faq {\n    padding: 70px 40px;\n    background: #f8f9ff;\n    max-width: 800px;\n    margin: 0 auto;\n  }\n  .skc-faq h2 {\n    font-size: 32px;\n    font-weight: 800;\n    color: #1b2d5b;\n    text-align: center;\n    margin: 0 0 40px;\n  }\n  .skc-faq-item {\n    border-bottom: 1px solid #e5e7eb;\n  }\n  .skc-faq-q {\n    width: 100%;\n    text-align: left;\n    background: none;\n    border: none;\n    padding: 20px 0;\n    font-size: 16px;\n    font-weight: 600;\n    color: #1b2d5b;\n    cursor: pointer;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n  .skc-faq-q::after {\n    content: \"∨\";\n    font-size: 20px;\n    color: #1b2d5b;\n    transition: transform 0.3s;\n    flex-shrink: 0;\n  }\n  .skc-faq-item.open .skc-faq-q::after { transform: rotate(180deg); }\n  .skc-faq-a {\n    display: none;\n    padding: 0 0 20px;\n    font-size: 15px;\n    color: #4b5563;\n    line-height: 1.75;\n  }\n  .skc-faq-item.open .skc-faq-a { display: block; }\n\n  /* --- MOBILE --- */\n  @media (max-width: 749px) {\n    .skc-trust-bar { gap: 16px; padding: 12px 16px; flex-direction: column; align-items: flex-start; }\n    .skc-features-grid { grid-template-columns: 1fr 1fr; gap: 12px; }\n    .skc-features-grid .skc-feature-item:last-child { grid-column: 1 / -1; max-width: 50%; margin: 0 auto; }\n    .skc-features { padding: 30px 12px; }\n    .skc-feature-item { padding: 16px 12px; }\n    .skc-feature-item h3 { font-size: 14px; }\n    .skc-feature-item ul li { font-size: 14px; line-height: 1.7; padding-left: 30px; }\n    .skc-hero { grid-template-columns: 1fr; }\n    .skc-hero-text { padding: 40px 24px; }\n    .skc-hero-text h2 { font-size: 28px; }\n    .skc-hero-img { min-height: 260px; }\n    .skc-usecases { padding: 40px 20px; }\n    .skc-usecases-grid { grid-template-columns: repeat(2, 1fr); }\n    .skc-stats-section { grid-template-columns: 1fr; }\n    .skc-stats-left { padding: 40px 24px 20px; }\n    .skc-stats-right { padding: 20px 24px 40px; }\n    .skc-reviews { padding: 40px 20px; }\n    .skc-reviews-grid { grid-template-columns: 1fr; }\n    .skc-compare { padding: 40px 20px; }\n    .skc-compare-inner { grid-template-columns: 1fr; gap: 32px; }\n    .skc-photo-strip { grid-template-columns: repeat(3, 1fr); }\n    .skc-photo-strip img:nth-child(n+4) { display: none; }\n    .skc-experts { padding: 40px 20px; }\n    .skc-experts-grid { grid-template-columns: 1fr; }\n    .skc-faq { padding: 40px 20px; }\n  }\n</style>\n\n<div class=\"skc-wrap\">\n\n  <!-- ===== 1. TRUST BAR ===== -->\n  <div class=\"skc-trust-bar\">\n    <span>Ergonomically Designed</span>\n    <span>1,000+ Happy Customers</span>\n    <span>30-Day Returns</span>\n  </div>\n\n  <!-- ===== 2. FIVE ANNOTATED FEATURES ===== -->\n  <section class=\"skc-features\">\n    <div class=\"skc-features-grid\">\n\n      <div class=\"skc-feature-item\">\n        <div class=\"skc-feature-img-wrap\">\n          <img src=\"https://snoozity.nl/cdn/shop/files/gempages_576690581959344994-87086e4c-4a49-4499-827f-bb4846d27eea.avif?v=1757650107&width=300\" alt=\"Comfortable Arm Support\" />\n        </div>\n        <h3>Comfortable Arm Support</h3>\n        <ul>\n          <li>No tingling or numb arms</li>\n          <li>Comfortable in every sleep position</li>\n          <li>Relaxation without pressure points</li>\n        </ul>\n      </div>\n\n      <div class=\"skc-feature-item\">\n        <div class=\"skc-feature-img-wrap\">\n          <img src=\"https://snoozity.nl/cdn/shop/files/gempages_576690581959344994-b69d1f01-6738-4b59-85e3-e58e9ab27d0b.avif?v=1757650107&width=300\" alt=\"Supportive Neck Wings\" />\n        </div>\n        <h3>Supportive Neck Wings</h3>\n        <ul>\n          <li>Correct spinal alignment</li>\n          <li>Less tension in neck and shoulders</li>\n          <li>Relax deeper, sleep more peacefully</li>\n        </ul>\n      </div>\n\n      <div class=\"skc-feature-item\">\n        <div class=\"skc-feature-img-wrap\">\n          <img src=\"https://snoozity.nl/cdn/shop/files/gempages_576690581959344994-87086e4c-4a49-4499-827f-bb4846d27eea.avif?v=1757650107&width=300\" alt=\"Ergonomic Central Core\" />\n        </div>\n        <h3>Ergonomic Central Core</h3>\n        <ul>\n          <li>Stable support for neck and chin</li>\n          <li>Always maintains its shape</li>\n          <li>Optimal pressure distribution for maximum comfort</li>\n        </ul>\n      </div>\n\n      <div class=\"skc-feature-item\">\n        <div class=\"skc-feature-img-wrap\">\n          <img src=\"https://snoozity.nl/cdn/shop/files/gempages_576690581959344994-87086e4c-4a49-4499-827f-bb4846d27eea.avif?v=1757650107&width=300\" alt=\"Supportive Back Wings\" />\n        </div>\n        <h3>Supportive Back Wings</h3>\n        <ul>\n          <li>Keeps your neck in the right position</li>\n          <li>Prevents tossing and turning in bed</li>\n          <li>Soft, yet firm where it counts</li>\n        </ul>\n      </div>\n\n      <div class=\"skc-feature-item\">\n        <div class=\"skc-feature-img-wrap\">\n          <img src=\"https://snoozity.nl/cdn/shop/files/gempages_576690581959344994-c594b5a1-e02a-443a-8819-c914defc5666.avif?v=1757650107&width=300\" alt=\"Shoulder Relief\" />\n        </div>\n        <h3>Shoulder Relief</h3>\n        <ul>\n          <li>Relieves tension in neck and shoulders</li>\n          <li>Promotes faster muscle recovery</li>\n          <li>Supports a healthy, upright posture</li>\n        </ul>\n      </div>\n\n    </div>\n  </section>\n\n  <!-- ===== 3. DARK HERO ===== -->\n  <section class=\"skc-hero\">\n    <div class=\"skc-hero-text\">\n      <h2>Relax Your Neck.</h2>\n      <p>Our support pillow gives new meaning to comfortable sleeping — something yo