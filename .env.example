# =============================================================================
# Blue Ocean Platform - Environment Variables
# Copy this file to .env and fill in your credentials.
# Everything is keyed to the Blue Ocean Commerce B.V. entity (GCP project
# `blue-ocean-platform-493819`, MCC 893-983-0325, Movanella 188-465-2074).
# =============================================================================

# --- OpenAI API ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Google Ads API ---
# STANDALONE client account (188-465-2074) linked under MCC 893-983-0325.
# LOGIN_CUSTOMER_ID must be set to the MCC ID so the dev token is accepted.
# Mint the refresh token via `python scripts/google_ads_oauth.py`.
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_desktop_oauth_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_desktop_oauth_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=your_customer_id_here  # Without dashes, e.g. 1884652074
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_mcc_id_here  # MCC ID without dashes

# --- Google Sheets API ---
# Service account JSON key with Editor access on the target spreadsheet.
# Share the sheet with the SA's client_email from the Sheet's share dialog.
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/google_service_account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# --- Google Merchant Center ---
GOOGLE_MERCHANT_CENTER_ID=your_merchant_center_id_here

# --- Shopify Admin API ---
# SHOPIFY_API_KEY/SECRET are only used by scripts/shopify_oauth.py (install
# flow) — runtime calls use SHOPIFY_ACCESS_TOKEN only.
SHOPIFY_SHOP_URL=your-store.myshopify.com
SHOPIFY_STOREFRONT_DOMAIN=your-custom-domain.com
SHOPIFY_API_KEY=your_shopify_app_api_key_here
SHOPIFY_API_SECRET=your_shopify_app_api_secret_here
SHOPIFY_ACCESS_TOKEN=your_shopify_admin_api_access_token_here

# --- AliExpress Drop Shipping / Open Platform API ---
# App registered under Portals account info@rovelloshop.com with "Drop Shipping"
# developer profile — so `aliexpress.ds.*` methods are available, but NOT
# `aliexpress.affiliate.*`. Tracking ID is created under Portals' Link Generator.
# Src uses feed-based browsing (see src/research/aliexpress.py docstring for
# the scope map of what works without OAuth).
ALIEXPRESS_APP_KEY=your_aliexpress_app_key_here
ALIEXPRESS_APP_SECRET=your_aliexpress_app_secret_here
ALIEXPRESS_TRACKING_ID=your_tracking_id_here

# --- SerpAPI ---
SERPAPI_KEY=your_serpapi_key_here

# --- Fal.ai (image generation) ---
FAL_KEY=your_fal_key_id:your_fal_key_secret

# --- Google Cloud / Vertex AI (Imagen 4, Gemini) ---
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Gemini API (Nano Banana image generation) ---
# Regenerate inside the BOC GCP project so billing flows to the right place.
GEMINI_API_KEY=your_gemini_api_key_here

# --- Page Cloner (Node service) ---
# Sibling Node service that does scraping + product creation. Defaults to
# localhost; override for remote deployments.
PAGE_CLONER_URL=http://localhost:3000

# --- Application Settings ---
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# POLLING_INTERVAL_MINUTES: How often to poll the sheet for agent updates
POLLING_INTERVAL_MINUTES=30
