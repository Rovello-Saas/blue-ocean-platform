# =============================================================================
# Streamlit Secrets — Blue Ocean Platform
# =============================================================================
# This file is a TEMPLATE. The real `secrets.toml` is gitignored; never commit
# it. On Streamlit Community Cloud, don't use a file at all — paste the
# populated TOML directly into the app's "Secrets" UI (Settings → Secrets).
#
# Local dev: copy this to `.streamlit/secrets.toml`, fill in values. The
# dashboard password gate and all API calls will then work without needing
# to also populate `.env` (either source is fine — `.env` wins for backward
# compat on the keys it already defines).
#
# The top-level keys here are available as `st.secrets["<key>"]`. Nothing
# maps them into `os.environ` automatically — if existing code only reads
# via `os.getenv`, we still need the same var in `.env` for local runs.
# The ONE exception we read from `st.secrets` is `dashboard_password` (see
# `_require_password` in `dashboard/app.py`).
# =============================================================================

# --- Password gate (REQUIRED on Cloud) -------------------------------------
# Single shared password; both Marc and Dennis sign in with the same one.
# Leave unset locally if you don't want a gate on your laptop.
dashboard_password = "change-me-to-something-long-and-random"

# --- LLM providers ---------------------------------------------------------
ANTHROPIC_API_KEY   = "sk-ant-..."
OPENAI_API_KEY      = "sk-..."
GEMINI_API_KEY      = "..."

# --- Google Ads API --------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN   = "..."
GOOGLE_ADS_CLIENT_ID         = "..."
GOOGLE_ADS_CLIENT_SECRET     = "..."
GOOGLE_ADS_REFRESH_TOKEN     = "..."
GOOGLE_ADS_CUSTOMER_ID       = "1884652074"      # no dashes
GOOGLE_ADS_LOGIN_CUSTOMER_ID = "8939830325"      # MCC, no dashes

# --- Google Sheets / Merchant Center ---------------------------------------
# On Cloud we pass the service account as a base64-encoded JSON blob.
# Generate with: base64 -i credentials/google_service_account.json | pbcopy
GOOGLE_SERVICE_ACCOUNT_JSON   = "<base64 string here>"
GOOGLE_SHEETS_SPREADSHEET_ID  = "..."
GOOGLE_SHEETS_AGENT_SPREADSHEET_ID = ""            # optional, see .env.example
GOOGLE_MERCHANT_CENTER_ID     = "..."
GOOGLE_CLOUD_PROJECT          = "blue-ocean-platform-493819"
GOOGLE_CLOUD_LOCATION         = "us-central1"

# --- Shopify ---------------------------------------------------------------
SHOPIFY_SHOP_URL          = "...myshopify.com"
SHOPIFY_STOREFRONT_DOMAIN = "..."
SHOPIFY_API_KEY           = "..."
SHOPIFY_API_SECRET        = "..."
SHOPIFY_ACCESS_TOKEN      = "shpat_..."

# --- AliExpress ------------------------------------------------------------
ALIEXPRESS_APP_KEY     = "..."
ALIEXPRESS_APP_SECRET  = "..."
ALIEXPRESS_TRACKING_ID = "..."

# --- Data APIs -------------------------------------------------------------
SERPAPI_KEY        = "..."
DATAFORSEO_LOGIN   = "..."
DATAFORSEO_PASSWORD = "..."

# --- Fal.ai ---------------------------------------------------------------
FAL_KEY = "key_id:key_secret"

# --- Deploy flags ---------------------------------------------------------
# Tell the app it's running on a hosted platform. The Clone page appears only
# when PAGE_CLONER_URL points at a public Page Cloner service.
BLUE_OCEAN_CLOUD_MODE = "1"
PAGE_CLONER_URL        = "https://your-page-cloner-service.example.com"
LOG_LEVEL             = "INFO"
